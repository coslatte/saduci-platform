  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.7.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.9",
    "@types/node": "^20.19.33",
